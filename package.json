{
  "name": "obsidian-glink",
  "version": "0.1.1",
  "description": "Open Google Drive placeholder files in Obsidian using a manual link registry",
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "keywords": [
    "obsidian",
    "google-drive",
    "google-docs",
    "google-sheets"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nedkelly/obsidian-glink.git"
  },
  "bugs": {
    "url": "https://github.com/nedkelly/obsidian-glink/issues"
  },
  "homepage": "https://github.com/nedkelly/obsidian-glink#readme",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.17",
    "esbuild": "0.25.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.1",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "obsidian": "^1.13.1",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  }
}
